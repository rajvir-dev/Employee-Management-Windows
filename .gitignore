## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is a combination of several sources:
## 1. The official Visual Studio .gitignore (https://github.com/github/gitignore/blob/master/VisualStudio.gitignore)
## 2. JetBrains .gitignore (https://github.com/github/gitignore/blob/master/Global/JetBrains.gitignore)

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
Log/
[Ll]og/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image rebasing files
Caption.txt

# Directory-specific settings
UpgradeLog.htm
Project_Readme.html

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Localization
#!**/[Pp]ackages/Microsoft.NETCore.Platforms.1.0.1/
# Restore MSAudit.json
!**/[Pp]ackages/MSAudit.json

# Microsoft Azure Build Output
csx/
*.pubxml
*.azurePubxml

# Others
sql/
*.cache
*.temp
*.tmp
*.log
*.zip
*.7z
*.rar
*.exe
*.dll

# Firebase / Agentic local logs
firebase_err.txt
firebase_out.txt
sequential_thinking_err.txt
sequential_thinking_out.txt
